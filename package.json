{
  "name": "repo-toolkit",
  "version": "0.1.0",
  "private": true,
  "description": "Shared monorepo for repository tooling packages",
  "license": "Apache-2.0",
  "author": "Junmin Ahn",
  "packageManager": "pnpm@10.14.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/egose/web-ts-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/egose/web-ts-toolkit/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint .",
    "lint-fix": "eslint --fix .",
    "build": "pnpm -r --if-present build",
    "changelog": "pnpm --filter @repo-toolkit/changelog build && node packages/changelog/dist/cli.js",
    "publish-package": "pnpm --filter @repo-toolkit/publish-package... build && node packages/publish-package/dist/cli.js",
    "publish-packages": "pnpm --filter @repo-toolkit/publish-packages... build && node packages/publish-packages/dist/cli.js",
    "release": "release-it",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/format": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@release-it/bumper": "^7.0.6",
    "@types/node": "^25.9.4",
    "eslint": "10.3.0",
    "globals": "^17.7.0",
    "prettier": "4.0.0-alpha.13",
    "release-it": "^20.2.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
