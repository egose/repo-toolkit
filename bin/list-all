#!/usr/bin/env bash
set -eo pipefail

# asdf repo-toolkit: list installable versions from GitHub releases.
#
# Resolves the GitHub <owner>/<repo> for this plugin from the local git remote
# of the checked-out plugin source (falling back to REPO_TOOLKIT_GITHUB_REPOSITORY),
# queries the GitHub releases API, prints every published tag (without the
# leading "v"), and sorts them with `sort -V`.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_TOOLKIT_HELPERS="${SCRIPT_DIR}/lib/repo-toolkit.sh"
# shellcheck source=bin/lib/repo-toolkit.sh
. "$REPO_TOOLKIT_HELPERS"

github_coordinates="${REPO_TOOLKIT_GITHUB_REPOSITORY:-$(repo_toolkit_resolve_github_coordinates "$SCRIPT_DIR")}"
releases_url="https://api.github.com/repos/${github_coordinates}/releases"

curl_opts=("-s")
if [ -n "${GITHUB_API_TOKEN:-}" ]; then
  curl_opts+=("-H" "Authorization: token $GITHUB_API_TOKEN")
fi

sort_versions() {
  sed 'h; s/[+-]/./g; s/.p\([[:digit:]]\)/.z\1/; s/$/.z/; G; s/\n/ /' |
    LC_ALL=C sort -V | cut -d ' ' -f 2
}

all_tags=""

for page in {1..3}; do
  current_url="${releases_url}?per_page=100&page=${page}"

  response=$(curl "${curl_opts[@]}" "$current_url")

  tags=$(echo "$response" | grep -o '"tag_name": *"[^"]*"' | sed -E 's/"tag_name": *"v?([^"]*)"/\1/' || true)

  if [ -z "$tags" ] || [ "$response" == "[]" ]; then
    break
  fi

  all_tags="${all_tags}${tags}"$'\n'
done

versions=$(echo "$all_tags" | sed '/^$/d' | sort_versions | xargs)

echo "$versions"
