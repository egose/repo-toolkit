{
  "name": "@repo-toolkit/publish-packages",
  "description": "Build, stage, and publish every package in a monorepo to npm",
  "version": "0.0.0-PLACEHOLDER",
  "license": "PLACEHOLDER",
  "repository": "PLACEHOLDER",
  "type": "module",
  "sideEffects": false,
  "keywords": [
    "monorepo",
    "publish",
    "npm",
    "release",
    "tooling"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "repo-toolkit-publish-packages": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "pnpm --filter @repo-toolkit/publish-packages... build && vitest run --config vitest.config.ts",
    "publish-packages": "node dist/cli.js"
  },
  "dependencies": {
    "@repo-toolkit/publish-package": "workspace:*"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=20"
  }
}
