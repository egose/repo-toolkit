#!/usr/bin/env bash
set -eo pipefail

# asdf repo-toolkit: list installable versions from GitHub releases.
#
# Resolves the GitHub <owner>/<repo> for this plugin from the local git remote
# of the checked-out plugin source (falling back to REPO_TOOLKIT_GITHUB_REPOSITORY),
# queries the GitHub releases API, keeps only releases that publish the
# expected asdf archive, prints every matching tag (without the leading "v"),
# and sorts them with `sort -V`.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_TOOLKIT_HELPERS="${SCRIPT_DIR}/lib/repo-toolkit.sh"
# shellcheck source=bin/lib/repo-toolkit.sh
. "$REPO_TOOLKIT_HELPERS"

github_coordinates="${REPO_TOOLKIT_GITHUB_REPOSITORY:-$(repo_toolkit_resolve_github_coordinates "$SCRIPT_DIR")}"
releases_url="https://api.github.com/repos/${github_coordinates}/releases"

sort_versions() {
  sed 'h; s/[+-]/./g; s/.p\([[:digit:]]\)/.z\1/; s/$/.z/; G; s/\n/ /' |
    LC_ALL=C sort -V | cut -d ' ' -f 2
}

all_tags=""

for page in {1..3}; do
  current_url="${releases_url}?per_page=100&page=${page}"

  response=$(repo_toolkit_api_get "$current_url")
  compact_response=$(printf '%s' "$response" | tr -d '[:space:]')

  tags=$(echo "$compact_response" | grep -o '"tag_name":"[^"]*"' | sed -E 's/"tag_name":"v?([^"]*)"/\1/' || true)

  if [ -z "$tags" ] || [ "$compact_response" == "[]" ]; then
    break
  fi

  while IFS= read -r tag; do
    [ -n "$tag" ] || continue

    filename="repo-toolkit-${tag}.tar.gz"
    assets_url=$(repo_toolkit_release_assets_url "$github_coordinates" "$tag" || true)

    if repo_toolkit_release_has_asset "$assets_url" "$filename"; then
      all_tags="${all_tags}${tag}"$'\n'
    fi
  done <<EOF
$tags
EOF
done

versions=$(echo "$all_tags" | sed '/^$/d' | sort_versions | xargs)

echo "$versions"
