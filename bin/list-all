#!/usr/bin/env bash
set -eo pipefail

# asdf repo-toolkit: list installable versions from GitHub releases.
#
# Resolves the GitHub <owner>/<repo> for this plugin from the local git remote
# of the checked-out plugin source (falling back to REPO_TOOLKIT_GITHUB_REPOSITORY),
# queries the GitHub releases API once, keeps only releases that publish the
# expected asdf archive, and prints their tags (without the leading "v"),
# sorted with `sort -V`.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_TOOLKIT_HELPERS="${SCRIPT_DIR}/lib/repo-toolkit.sh"
# shellcheck source=bin/lib/repo-toolkit.sh
. "$REPO_TOOLKIT_HELPERS"

tool_name="repo-toolkit"

github_coordinates="${REPO_TOOLKIT_GITHUB_REPOSITORY:-$(repo_toolkit_resolve_github_coordinates "$SCRIPT_DIR")}"

releases_json=$(repo_toolkit_fetch_releases "$github_coordinates")

repo_toolkit_list_installable_versions "$releases_json" "^${tool_name}-.+\.tar\.gz$"
